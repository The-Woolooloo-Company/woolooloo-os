# Linear API
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret_here

# Clockify API
CLOCKIFY_API_KEY=your_clockify_api_key_here
CLOCKIFY_WORKSPACE_ID=your_clockify_workspace_id_here

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_repo_name

# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_FOUNDER_INBOX_ID=your_notion_db_id
NOTION_CAMPAIGNS_DB_ID=your_campaigns_db_id

# Slack
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=your_twilio_whatsapp_number

# Xero
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_TENANT_ID=your_xero_tenant_id

# vLLM
VLLM_HOST=http://localhost:8000
VLLM_MODEL=Qwen3.5-27B
VLLM_API_KEY=your_vllm_api_key
