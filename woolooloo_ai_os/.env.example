# Application
APP_NAME="Woolooloo AI OS"
APP_VERSION="0.1.0"
DEBUG=true
SECRET_KEY="change-this-to-a-secure-random-string"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/woolooloo_os"

# Redis
REDIS_URL="redis://localhost:6379/0"

# vLLM (Primary LLM)
VLLM_HOST="http://localhost:8000"
VLLM_MODEL="qwen3.5-27b"
VLLM_API_KEY=""
VLLM_TIMEOUT=120

# OpenRouter (Fallback LLM)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="qwen/qwen3.5-27b"

# Linear
LINEAR_API_KEY=""
LINEAR_WEBHOOK_SECRET=""
LINEAR_TEAM_ID=""

# Notion
NOTION_API_KEY=""
NOTION_FOUNDER_INBOX_ID=""
NOTION_CAMPAIGNS_DB_ID=""
NOTION_LEADS_DB_ID=""
NOTION_PROPOSALS_DB_ID=""

# Slack
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_APP_TOKEN=""

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Xero
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_TENANT_ID=""

# OpenCode
OPENCODE_API_URL="http://localhost:18888"
OPENCODE_API_KEY=""

# Ops Thresholds
CHURN_RISK_DAYS=30
CHURN_FAILED_PAYMENTS=2
REVENUE_DROP_THRESHOLD=0.10
USAGE_SPIKE_THRESHOLD=0.50